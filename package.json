{
  "name": "@librecord/pipecap",
  "version": "0.1.0",
  "description": "Native PipeWire screen capture for Electron — xdg-desktop-portal picker + video frames",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LibreCommunications/pipecap"
  },
  "os": ["linux"],
  "napi": {
    "name": "pipecap",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "artifacts": "napi artifacts",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "electron/"
  ]
}
